# Caddy 가 Let's Encrypt 인증서 발급/갱신을 자동 처리한다(certbot 수동 설정 불필요).
# 호스트네임에 도메인이 있으면 Caddy 는 기본적으로 HTTP(80)->HTTPS(443) 리다이렉트도 자동 처리한다.

sellerprofit.co.kr {
	# 보안 취약점 감사(2026-07) 후속 조치 — 응답 헤더에 기본 보안 헤더를 추가한다.
	# CSP 는 SPA + 인라인 스타일/스크립트 사용 여부를 더 확인한 뒤 별도로 좁혀 넣을 예정이라
	# 우선 나머지 표준 헤더만 켠다(과도하게 좁힌 CSP를 잘못 넣으면 화면이 통째로 깨질 수 있어서다).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		-Server
	}
	reverse_proxy app:8080
}

# T12.2 에서 www 서브도메인까지 A 레코드를 연결한 경우를 대비한 안전망.
# (연결하지 않았다면 이 블록은 아무 트래픽도 받지 않으므로 무해하다.)
www.sellerprofit.co.kr {
	redir https://sellerprofit.co.kr{uri} permanent
}
