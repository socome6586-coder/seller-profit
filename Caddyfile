# Caddy 가 Let's Encrypt 인증서 발급/갱신을 자동 처리한다(certbot 수동 설정 불필요).
# 호스트네임에 도메인이 있으면 Caddy 는 기본적으로 HTTP(80)->HTTPS(443) 리다이렉트도 자동 처리한다.

sellerprofit.co.kr {
	reverse_proxy app:8080
}

# T12.2 에서 www 서브도메인까지 A 레코드를 연결한 경우를 대비한 안전망.
# (연결하지 않았다면 이 블록은 아무 트래픽도 받지 않으므로 무해하다.)
www.sellerprofit.co.kr {
	redir https://sellerprofit.co.kr{uri} permanent
}
