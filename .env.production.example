# 운영 환경변수 템플릿. 실제 값을 채운 뒤 서버에서 파일명을 `.env.production` 으로 저장한다.
# 이 .example 파일만 커밋 대상이다 — `.env.production`(실제 값)은 .gitignore 로 커밋 차단됨.
#
# 사용:
#   cp .env.production.example .env.production   # 서버에서, 값 채운 뒤
#   docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

# --- PostgreSQL ---
# 로컬 docker-compose.yml 의 postgres/postgres 를 운영에 그대로 쓰지 않는다.
DB_USERNAME=seller_profit_app
DB_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# --- 애플리케이션 암복호화 키 (Base64 32byte / AES-256) ---
# 생성: openssl rand -base64 32
APP_ENCRYPTION_KEY=CHANGE_ME_BASE64_32BYTE_KEY

# --- 관리자 부트스트랩 이메일 (콤마로 구분, 조민석 님 실제 이메일로 설정) ---
# 비워두면 운영에서 아무도 /admin 에 접근할 수 없다.
APP_ADMIN_EMAILS=CHANGE_ME@example.com

# --- 토스페이먼츠 빌링 ---
# 라이브 키 발급 전에는 비워두거나 플레이스홀더 그대로 둔다(결제 호출만 503으로 안전하게 차단,
# 요금제 카탈로그/무료 가입은 정상 동작).
TOSS_SECRET_KEY=test_sk_PLACEHOLDER
TOSS_BASE_URL=https://api.tosspayments.com

# --- Spring 프로파일 ---
# 반드시 비워두거나 prod. seed 절대 금지(로컬 데모 전용 — 시드 데이터/데모 계정이 운영에 생긴다).
SPRING_PROFILES_ACTIVE=

# --- (선택) JVM 힙 상한 ---
# KR1-Lite 등 RAM 1~2GB 서버에서 Postgres/Caddy 와 공존하기 위한 기본값이 docker-compose.prod.yml
# 에 이미 있다(-Xmx384m). 서버 RAM 이 더 넉넉하면 이 값을 덮어써서 늘릴 수 있다.
# APP_JAVA_OPTS=-Xmx768m -XX:MaxMetaspaceSize=192m
